{
  "name": "monaco-angular",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Worker for Angular language service in the Monaco Editor",
  "type": "module",
  "keywords": [
    "angular",
    "monaco",
    "monaco-editor",
    "worker",
    "language-service"
  ],
  "scripts": {
    "dev": "rolldown build --config rolldown.config.js --watch",
    "build": "rolldown build --config rolldown.config.js"
  },
  "author": "sebheron",
  "license": "MIT",
  "packageManager": "pnpm@10.33.1",
  "devDependencies": {
    "@angular/language-service": "21.2.10",
    "rolldown": "1.0.0-rc.16"
  },
  "peerDependencies": {
    "monaco-editor": ">0.55.0"
  },
  "dependencies": {
    "path-browserify-esm": "^1.0.6"
  },
  "types": "./main.d.ts",
  "exports": {
    "./worker": "./esm/monaco-angular.worker.js",
    ".": {
      "import": "./esm/monaco-angular.js",
      "types": "./main.d.ts"
    }
  },
  "files": [
    "README.md",
    "build.js",
    "licenses.json",
    "main.d.ts",
    "./esm/monaco-angular.js",
    "./esm/monaco-angular.worker.js"
  ]
}
